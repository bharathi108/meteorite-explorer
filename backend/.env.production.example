# Production: prefer setting these in your host (Render, Fly, etc.) rather than a file on disk.
# If you do use a file, copy to .env.production and set APP_ENV=production when starting the API.

APP_ENV=production

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# DATABASE_URL=sqlite:///./meteorites.db

# Required in production — your deployed frontend origin(s)
CORS_ORIGINS=https://your-app.example.com

LOG_LEVEL=INFO
