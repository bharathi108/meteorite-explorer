# Copy to .env.development (gitignored) for local development.
# Loaded automatically when APP_ENV=development (the default).

APP_ENV=development

OPENAI_API_KEY=sk-your-dev-key-here
# OPENAI_MODEL=gpt-4o-mini

# SQLite by default; override if needed
# DATABASE_URL=sqlite:///./meteorites.db

# Comma-separated origins, or * for local dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_LEVEL=DEBUG
